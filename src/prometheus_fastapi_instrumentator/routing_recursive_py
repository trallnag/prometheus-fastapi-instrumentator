"""Helper module for routing.

The two functions in this module are licensed under the BSD 3-Clause License
instead of the ISC License like the rest of the project. Therefore the code
is contained in a dedicated module.

Based on code from [elastic/apm-agent-python](https://github.com/elastic/apm-agent-python/blob/527f62c0c50842f94ef90fda079853372539319a/elasticapm/contrib/starlette/__init__.py).
"""

from typing import Any, Iterable, List, Optional

from starlette.requests import HTTPConnection
from starlette.routing import Match, Mount, Route
from starlette.types import Scope

try:
    from fastapi.routing import iter_route_contexts as _iter_fastapi_route_contexts
except ImportError:
    _iter_fastapi_route_contexts = None


def _iter_routes_with_context(routes: List[Any]) -> Iterable[Any]:
    """Yields route objects with include_router context when FastAPI provides it."""

    if _iter_fastapi_route_contexts is None:
        return routes

    return _iter_fastapi_route_contexts(routes)


def _get_path_from_effective_candidates(route: Any, scope: Scope) -> Optional[str]:
    """Extract the full templated path from FastAPI's include-router wrapper.

    FastAPI >= 0.137 can keep include_router registrations as wrapper routes
    that do not expose ``.path``. Those wrappers cache concrete candidates that
    carry the full ``path_format`` (including include_router prefixes).
    """

    candidates = getattr(route, "_effective_candidates", None)
    if not candidates:
        return None

    for candidate in candidates:
        candidate_path = getattr(candidate, "path_format", None)
        if candidate_path is None:
            candidate_path = getattr(candidate, "path", None)
        if candidate_path is None:
            continue

        match, _ = candidate.matches(scope)
        if match == Match.FULL:
            return candidate_path

    return None


def _get_route_name(
    scope: Scope,
    routes: List[Any],
    route_name: Optional[str] = None,
    use_fastapi_contexts: bool = True,
) -> Optional[str]:
    """Gets route name for given scope taking mounts into account."""

    routes_to_iterate = _iter_routes_with_context(routes) if use_fastapi_contexts else routes

    for route in routes_to_iterate:
        match, child_scope = route.matches(scope)
        original_route = getattr(route, "original_route", route)
        route_path = getattr(route, "path", None)
        if route_path is None:
            route_path = getattr(route, "path_format", None)
        if route_path is None:
            route_path = _get_path_from_effective_candidates(route, scope)
        if match == Match.FULL:
            if route_path is not None:
                route_name = route_path
            child_scope = {**scope, **child_scope}
            child_routes = getattr(original_route, "routes", None)
            if isinstance(original_route, Mount) and child_routes:
                child_route_name = _get_route_name(
                    child_scope,
                    child_routes,
                    route_name,
                    use_fastapi_contexts=False,
                )
                if child_route_name is None:
                    route_name = None
                else:
                    route_name += child_route_name
            elif route_path is None:
                if child_routes:
                    route_name = _get_route_name(
                        child_scope,
                        child_routes,
                        route_name,
                        use_fastapi_contexts=False,
                    )
            return route_name
        elif match == Match.PARTIAL and route_name is None:
            if route_path is not None:
                route_name = route_path
    return None


def get_route_name(request: HTTPConnection) -> Optional[str]:
    """Gets route name for given request taking mounts into account."""

    app = request.app
    scope = request.scope
    routes = app.routes
    route_name = _get_route_name(scope, routes)

    # Starlette magically redirects requests if the path matches a route name
    # with a trailing slash appended or removed. To not spam the transaction
    # names list, we do the same here and put these redirects all in the
    # same "redirect trailing slashes" transaction name.
    if not route_name and app.router.redirect_slashes and scope["path"] != "/":
        redirect_scope = dict(scope)
        if scope["path"].endswith("/"):
            redirect_scope["path"] = scope["path"][:-1]
            trim = True
        else:
            redirect_scope["path"] = scope["path"] + "/"
            trim = False

        route_name = _get_route_name(redirect_scope, routes)
        if route_name is not None:
            route_name = route_name + "/" if trim else route_name[:-1]
    return route_name
